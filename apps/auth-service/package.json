{
  "name": "@ums/auth-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "start": "node --env-file=../../.env dist/index.js",
    "typecheck": "tsc -b --pretty false",
    "dev": "pnpm build && pnpm start",
    "dev:watch": "tsc -b --watch --preserveWatchOutput",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@ums/core": "workspace:*",
    "@ums/db": "workspace:*",
    "@ums/queue": "workspace:*",
    "bcrypt": "^5.1.1",
    "fastify": "^5.3.3",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.15.24"
  }
}
