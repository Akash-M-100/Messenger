{
  "name": "@ums/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "dev": "tsc -b --watch --preserveWatchOutput",
    "clean": "tsc -b --clean",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema ./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema ./prisma/schema.prisma",
    "db:studio": "prisma studio --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.24",
    "prisma": "^6.8.2"
  }
}
