generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum MessageChannel {
  SMS
  EMAIL
  WHATSAPP
  VOICE
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  DISPATCHED
  DELIVERED
  FAILED
  SCHEDULED
  CANCELED
}

enum TemplateStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ProviderType {
  SMS
  EMAIL
  WHATSAPP
  VOICE
}

model Tenant {
  id        String       @id @default(cuid())
  name      String       @db.VarChar(160)
  slug      String       @unique @db.VarChar(80)
  status    TenantStatus @default(ACTIVE)
  metadata  Json?
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)

  apiKeys              ApiKey[]
  messages             Message[]
  templates            Template[]
  providerIntegrations ProviderIntegration[]

  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("tenants")
}

model ApiKey {
  id         String       @id @default(cuid())
  tenantId   String       @map("tenant_id")
  name       String       @db.VarChar(120)
  keyPrefix  String       @map("key_prefix") @db.VarChar(16)
  keyHash    String       @unique @map("key_hash") @db.VarChar(128)
  status     ApiKeyStatus @default(ACTIVE)
  scopes     String[]     @default([])
  expiresAt  DateTime?    @map("expires_at") @db.Timestamptz(6)
  lastUsedAt DateTime?    @map("last_used_at") @db.Timestamptz(6)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt  DateTime?    @map("revoked_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, keyPrefix])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([expiresAt])
  @@map("api_keys")
}

model Message {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  idempotencyKey String?          @map("idempotency_key") @db.VarChar(160)
  externalId     String?          @map("external_id") @db.VarChar(160)
  channel        MessageChannel
  direction      MessageDirection
  status         MessageStatus    @default(QUEUED)
  fromAddress    String?          @map("from_address") @db.VarChar(320)
  toAddress      String           @map("to_address") @db.VarChar(320)
  subject        String?          @db.VarChar(998)
  body           String?
  payload        Json?
  metadata       Json?
  errorCode      String?          @map("error_code") @db.VarChar(80)
  errorMessage   String?          @map("error_message")
  scheduledAt    DateTime?        @map("scheduled_at") @db.Timestamptz(6)
  sentAt         DateTime?        @map("sent_at") @db.Timestamptz(6)
  deliveredAt    DateTime?        @map("delivered_at") @db.Timestamptz(6)
  failedAt       DateTime?        @map("failed_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, externalId])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, channel, status])
  @@index([tenantId, direction, createdAt])
  @@index([tenantId, toAddress])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("messages")
}

model Provider {
  id          String       @id @default(cuid())
  providerId  String       @unique @db.VarChar(80) // e.g., "msg91", "meta_cloud", "resend"
  type        ProviderType
  name        String       @db.VarChar(160)
  description String?      @db.Text
  baseUrl     String?      @db.VarChar(500)
  isActive    Boolean      @default(true)
  config      Json? // Store provider-specific configuration
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  integrations ProviderIntegration[]

  @@index([type, isActive])
  @@map("providers")
}

model ProviderIntegration {
  id         String         @id @default(cuid())
  tenantId   String         @map("tenant_id")
  providerId String         @map("provider_id")
  channel    MessageChannel
  apiKey     String         @map("api_key") @db.VarChar(500) // Encrypted
  apiSecret  String?        @map("api_secret") @db.VarChar(500) // Encrypted
  config     Json? // Provider-specific configuration for this tenant
  isActive   Boolean        @default(true)
  priority   Int            @default(0) // Higher priority = preferred for this channel
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([tenantId, providerId, channel])
  @@index([tenantId, channel, isActive])
  @@index([providerId, isActive])
  @@map("provider_integrations")
}

model Template {
  id        String         @id @default(cuid())
  tenantId  String         @map("tenant_id")
  channel   MessageChannel
  language  String         @default("en") @db.VarChar(20)
  name      String         @db.VarChar(160)
  body      String         @db.Text
  subject   String?        @db.VarChar(998) // For email
  variables Json? // List of template variables
  status    TemplateStatus @default(DRAFT)
  version   Int            @default(1)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([tenantId, channel, name, language])
  @@index([tenantId, channel, status])
  @@index([tenantId, createdAt])
  @@map("templates")
}
