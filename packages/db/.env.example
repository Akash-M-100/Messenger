# PostgreSQL connection string used by Prisma Client at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ums?schema=public"

# Direct PostgreSQL connection used by Prisma Migrate.
# In pooled production deployments, keep DATABASE_URL pointed at the pooler and DIRECT_URL at the database.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ums?schema=public"
